<!-- pages/myPosts/myPosts.wxml -->
<view class="page">
  <view class="header">
    <text class="header-title">我发布的帖子</text>
    <text class="header-sub">你创作过的所有穿搭内容</text>
  </view>

  <view class="empty-state" wx:if="{{postList.length === 0 && !loading}}">
    <view class="empty-orb"></view>
    <text class="empty-kicker">NO POSTS YET</text>
    <text class="empty-title">你还没有发布过穿搭</text>
    <text class="empty-desc">去发现页上传你的第一套穿搭吧。</text>
  </view>

  <view class="loading-tip" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="post-list" wx:if="{{postList.length > 0}}">
    <view class="post-item" wx:for="{{postList}}" wx:key="id">
      <image class="post-img" src="{{item.image}}" mode="aspectFill" bindtap="goDetail" data-id="{{item.id}}"></image>
      <view class="post-info">
        <text class="post-desc" bindtap="goDetail" data-id="{{item.id}}">{{item.desc || '无说明'}}</text>
        <view class="post-tags" wx:if="{{item.tags.length > 0}}">
          <text class="post-tag" wx:for="{{item.tags}}" wx:key="index" wx:for-item="tag"># {{tag}}</text>
        </view>
        <view class="post-meta">
          <text class="post-stat">♥ {{item.likes}}</text>
          <text class="post-stat">💬 {{item.comments}}</text>
        </view>
      </view>
      <text class="post-del" catchtap="deletePost" data-id="{{item.id}}">删除</text>
    </view>
  </view>
</view>
