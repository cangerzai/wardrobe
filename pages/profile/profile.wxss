/* pages/profile/profile.wxss */
.page {
  min-height: 100vh;
  padding: 32rpx 24rpx 48rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(212, 167, 98, 0.22), transparent 30%),
    radial-gradient(circle at left 16%, rgba(101, 79, 63, 0.12), transparent 24%),
    linear-gradient(180deg, #f8f2e9 0%, #efe4d2 42%, #eadcc9 100%);
}

.hero {
  background: linear-gradient(135deg, rgba(59, 43, 33, 0.96) 0%, rgba(90, 66, 50, 0.92) 58%, rgba(163, 118, 74, 0.88) 100%);
  border-radius: 36rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 20rpx 50rpx rgba(69, 43, 20, 0.18);
  color: #fff9f1;
  position: relative;
  overflow: hidden;
}

.hero::after {
  content: '';
  position: absolute;
  right: -44rpx;
  top: -24rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 237, 214, 0.08);
}

.hero-copy {
  position: relative;
  z-index: 1;
}

.eyebrow {
  display: block;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: rgba(255, 243, 225, 0.72);
  margin-bottom: 18rpx;
}

.hero-title {
  display: block;
  font-size: 60rpx;
  font-weight: 700;
  color: #fffaf3;
  margin-bottom: 18rpx;
}

.hero-subtitle {
  display: block;
  max-width: 600rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: rgba(255, 243, 225, 0.84);
}

.profile-shell {
  position: relative;
  z-index: 1;
  margin-top: 34rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 247, 236, 0.14);
  border: 1rpx solid rgba(255, 240, 220, 0.16);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #fff3e3;
  border: 4rpx solid rgba(255, 246, 235, 0.3);
}

.profile-copy {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.username {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff9f1;
}

.user-desc {
  font-size: 24rpx;
  color: rgba(255, 243, 225, 0.8);
}

.stats-grid {
  margin-top: 26rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.stat-card {
  background: rgba(255, 251, 247, 0.92);
  border-radius: 26rpx;
  padding: 26rpx 20rpx;
  text-align: center;
  box-shadow: 0 12rpx 28rpx rgba(95, 67, 37, 0.08);
}

.accent-card {
  background: linear-gradient(135deg, #4f392a 0%, #8f6548 100%);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #8f7257;
}

.accent-card .stat-label {
  color: rgba(255, 244, 232, 0.76);
}

.stat-value {
  display: block;
  margin-top: 12rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #3b2b21;
}

.accent-card .stat-value {
  color: #fff8ef;
}

.section-head {
  margin: 34rpx 8rpx 22rpx;
}

.compact-head {
  margin-top: 28rpx;
}

.section-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #3b2b21;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8f7257;
}

.favorites-empty {
  position: relative;
  overflow: hidden;
  background: rgba(255, 250, 244, 0.88);
  border-radius: 32rpx;
  padding: 72rpx 42rpx;
  text-align: center;
  box-shadow: 0 14rpx 36rpx rgba(95, 67, 37, 0.08);
}

.empty-orb {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, #f8e8d1 0%, #d1ab7d 42%, #7e5c42 100%);
  opacity: 0.9;
}

.empty-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 5rpx;
  color: #a17f5d;
  margin-bottom: 14rpx;
}

.empty-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #3b2b21;
  margin-bottom: 16rpx;
}

.empty-desc {
  display: block;
  font-size: 24rpx;
  line-height: 1.9;
  color: #8c6f56;
}

.menu-panel {
  background: rgba(255, 251, 247, 0.92);
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 36rpx rgba(95, 67, 37, 0.1);
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 28rpx;
  border-bottom: 1rpx solid rgba(111, 85, 63, 0.08);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon-wrap {
  width: 74rpx;
  height: 74rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #f7ede1 0%, #f2e3cf 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon {
  font-size: 34rpx;
}

.menu-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.menu-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #352419;
}

.menu-note {
  font-size: 22rpx;
  color: #977960;
}

.menu-arrow {
  font-size: 28rpx;
  color: #8a6c53;
}

.action-section {
  margin-top: 26rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.action-btn {
  width: 100%;
  border: none;
  border-radius: 999rpx;
  font-size: 28rpx;
}

.action-btn::after {
  border: none;
}

.action-btn.danger {
  background: rgba(255, 251, 247, 0.92);
  color: #8b3f37;
}

.action-btn.soft {
  background: linear-gradient(135deg, #4f392a 0%, #8f6548 100%);
  color: #fff8ef;
}

/* 收藏列表 */
.fav-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 8rpx;
}

.fav-card {
  display: flex;
  gap: 20rpx;
  background: rgba(255, 251, 247, 0.92);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(95, 67, 37, 0.08);
}

.fav-image {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
}

.fav-body {
  flex: 1;
  padding: 20rpx 20rpx 20rpx 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  justify-content: center;
}

.fav-desc {
  font-size: 28rpx;
  font-weight: 600;
  color: #3c2a1f;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.fav-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.fav-tag {
  font-size: 20rpx;
  color: #8b6344;
  background: rgba(143, 101, 72, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.fav-user {
  font-size: 22rpx;
  color: #9a7d63;
}

.section-head-tap {
  cursor: pointer;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.section-toggle {
  font-size: 28rpx;
  color: #a17f5d;
  padding-left: 16rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

/* 我发布的帖子入口 */
.my-posts-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: rgba(255, 247, 236, 0.16);
  border: 1rpx solid rgba(255, 240, 220, 0.22);
}

.my-posts-entry-text {
  font-size: 26rpx;
  color: rgba(255, 243, 225, 0.9);
  font-weight: 600;
}

.my-posts-entry-arrow {
  font-size: 24rpx;
  color: rgba(255, 243, 225, 0.7);
}

.my-posts-list {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.my-posts-empty {
  padding: 24rpx 0;
  text-align: center;
}

.my-posts-empty-text {
  font-size: 24rpx;
  color: rgba(255, 243, 225, 0.6);
}

.my-post-item {
  display: flex;
  gap: 16rpx;
  background: rgba(255, 247, 236, 0.14);
  border-radius: 18rpx;
  overflow: hidden;
  align-items: stretch;
}

.my-post-img {
  width: 140rpx;
  height: 140rpx;
  flex-shrink: 0;
}

.my-post-info {
  flex: 1;
  padding: 16rpx 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  justify-content: center;
}

.my-post-desc {
  font-size: 26rpx;
  color: rgba(255, 248, 238, 0.92);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.my-post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.my-post-tag {
  font-size: 20rpx;
  color: rgba(255, 243, 225, 0.72);
  background: rgba(255, 247, 236, 0.14);
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
}

.my-post-meta {
  display: flex;
  gap: 16rpx;
}

.my-post-stat {
  font-size: 22rpx;
  color: rgba(255, 243, 225, 0.6);
}

.my-post-del {
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: rgba(220, 100, 80, 0.9);
  flex-shrink: 0;
}
