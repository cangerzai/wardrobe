<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
    <text class="username">{{userInfo.nickName || '未登录'}}</text>
    <text class="user-desc">我的个性化电子衣橱</text>
  </view>

  <!-- 统计信息 -->
  <view class="stats-section">
    <view class="stat-item" bindtap="goToWardrobe">
      <text class="stat-value">{{clothesCount}}</text>
      <text class="stat-label">我的服装</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{outfitCount}}</text>
      <text class="stat-label">穿搭记录</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{favoriteCount}}</text>
      <text class="stat-label">收藏</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="manageData">
      <text class="menu-icon">📦</text>
      <text class="menu-text">数据管理</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="settings">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">设置</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="about">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <button class="action-btn" bindtap="clearAllData">清空所有数据</button>
    <button class="action-btn secondary" bindtap="exportData">导出数据</button>
  </view>
</view>
