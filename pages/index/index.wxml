<!-- pages/index/index.wxml -->
<view class="page">

  <!-- 顶部标题 -->
  <view class="hero">
    <view class="hero-copy">
      <text class="eyebrow">LOOKBOOK</text>
      <text class="hero-title">虚拟试衣间</text>
      <text class="hero-subtitle">选择分类，左右滑动切换服装，两件同时搭配预览。</text>
    </view>
  </view>

  <!-- 换装舞台 -->
  <view class="stage-wrap">

    <!-- 左上角分类下拉 -->
    <view class="category-selector">
      <view class="selector-btn" bindtap="toggleDropdown">
        <text class="selector-label">{{categoryLabel}}</text>
        <text class="selector-arrow">{{showDropdown ? '▲' : '▼'}}</text>
      </view>
      <view class="dropdown-menu" wx:if="{{showDropdown}}">
        <view class="dropdown-item {{activeCategory === 'top' ? 'active' : ''}}" bindtap="selectCategory" data-cat="top" data-label="上衣">
          <text>上衣</text>
        </view>
        <view class="dropdown-item {{activeCategory === 'pants' ? 'active' : ''}}" bindtap="selectCategory" data-cat="pants" data-label="裤子">
          <text>裤子</text>
        </view>
      </view>
    </view>

    <!-- 模特展示区 -->
    <view
      class="model-stage"
      bindtouchstart="onTouchStart"
      bindtouchend="onTouchEnd"
    >
      <!-- 模特底图 -->
      <image class="model-img" src="/images/model.png" mode="scaleToFill"></image>

      <!-- 上衣叠加层（始终显示已选上衣）-->
      <view style="{{topStyle}}" wx:if="{{selectedTop && selectedTop.cartoonUrl}}">
        <image
          class="clothes-img"
          src="{{selectedTop.cartoonUrl}}"
          mode="aspectFit"
          style="width:100%;height:100%;"
        ></image>
      </view>

      <!-- 裤子叠加层（始终显示已选裤子，z-index 低于上衣）-->
      <view style="{{pantsStyle}}" wx:if="{{selectedPants && selectedPants.cartoonUrl}}">
        <image
          class="clothes-img"
          src="{{selectedPants.cartoonUrl}}"
          mode="aspectFit"
          style="width:100%;height:100%;"
        ></image>
      </view>

      <!-- 空状态提示 -->
      <view class="stage-empty" wx:if="{{filteredList.length === 0}}">
        <text class="stage-empty-text">暂无{{categoryLabel}}，去衣橱上传吧</text>
      </view>

      <!-- 左右切换提示箭头 -->
      <view class="swipe-hint" wx:if="{{filteredList.length > 1}}">
        <text class="swipe-arrow left-arrow">‹</text>
        <text class="swipe-arrow right-arrow">›</text>
      </view>
    </view>

    <!-- 当前分类服装信息 -->
    <view class="clothes-info" wx:if="{{filteredList.length > 0}}">
      <view class="outfit-summary">
        <text class="outfit-label">当前{{categoryLabel}}</text>
        <text class="clothes-name">{{currentClothes.name || '服装单品'}}</text>
      </view>
      <view class="clothes-index">
        <text class="clothes-index-text">{{currentFilterIndex + 1}} / {{filteredList.length}}</text>
      </view>
    </view>

    <!-- 指示点 -->
    <view class="indicator" wx:if="{{filteredList.length > 1}}">
      <view
        class="indicator-dot {{index === currentFilterIndex ? 'active' : ''}}"
        wx:for="{{filteredList}}"
        wx:key="id"
      ></view>
    </view>

  </view>

</view>
