/* pages/index/index.wxss */
.page {
  min-height: 100vh;
  padding: 32rpx 24rpx 60rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(212, 167, 98, 0.22), transparent 30%),
    radial-gradient(circle at left 16%, rgba(101, 79, 63, 0.12), transparent 24%),
    linear-gradient(180deg, #f8f2e9 0%, #efe4d2 42%, #eadcc9 100%);
}

/* ── 顶部标题 ── */
.hero {
  background: linear-gradient(135deg, rgba(59, 43, 33, 0.96) 0%, rgba(90, 66, 50, 0.92) 58%, rgba(163, 118, 74, 0.88) 100%);
  border-radius: 36rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 20rpx 50rpx rgba(69, 43, 20, 0.18);
  color: #fff9f1;
  margin-bottom: 32rpx;
}

.eyebrow {
  display: block;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: rgba(255, 243, 225, 0.72);
  margin-bottom: 14rpx;
}

.hero-title {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #fffaf3;
  margin-bottom: 14rpx;
}

.hero-subtitle {
  display: block;
  font-size: 24rpx;
  line-height: 1.8;
  color: rgba(255, 243, 225, 0.84);
}

/* ── 换装舞台整体 ── */
.stage-wrap {
  background: rgba(255, 251, 247, 0.92);
  border-radius: 36rpx;
  padding: 24rpx 24rpx 32rpx;
  box-shadow: 0 16rpx 40rpx rgba(95, 67, 37, 0.1);
  position: relative;
}

/* ── 分类下拉 ── */
.category-selector {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  z-index: 20;
}

.selector-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(59, 43, 33, 0.88);
  border-radius: 999rpx;
  padding: 14rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(59, 43, 33, 0.25);
}

.selector-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #fff9f1;
}

.selector-arrow {
  font-size: 20rpx;
  color: rgba(255, 243, 225, 0.8);
}

.dropdown-menu {
  margin-top: 10rpx;
  background: #fff9f1;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 28rpx rgba(59, 43, 33, 0.18);
  border: 1rpx solid rgba(143, 101, 72, 0.15);
}

.dropdown-item {
  padding: 22rpx 36rpx;
  font-size: 26rpx;
  color: #4c3625;
  font-weight: 500;
}

.dropdown-item.active {
  background: rgba(79, 57, 42, 0.08);
  color: #3c2a1f;
  font-weight: 700;
}

/* ── 模特展示区 ── */
.model-stage {
  position: relative;
  width: 100%;
  min-height: 880rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at top, rgba(255, 249, 240, 0.6), transparent 50%),
    linear-gradient(180deg, #f2e8da 0%, #e8dace 100%);
}

.model-img {
  width: 100%;
  height: 880rpx;
  display: block;
}

/* ── 服装叠加层 ── */
.clothes-overlay {
  position: absolute;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

/* 上衣叠加在上半身 */
.top-overlay {
  top: 22%;
  height: 36%;
}

/* 裤子叠加在下半身 */
.pants-overlay {
  top: 54%;
  height: 36%;
}

.clothes-img {
  width: 72%;
  height: 100%;
}

/* ── 空状态 ── */
.stage-empty {
  position: absolute;
  bottom: 30rpx;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stage-empty-text {
  font-size: 24rpx;
  color: rgba(92, 65, 46, 0.6);
  background: rgba(255, 251, 247, 0.85);
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
}

/* ── 左右箭头提示 ── */
.swipe-hint {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  transform: translateY(-50%);
  display: flex;
  justify-content: space-between;
  padding: 0 16rpx;
  pointer-events: none;
}

.swipe-arrow {
  font-size: 72rpx;
  color: rgba(92, 65, 46, 0.25);
  font-weight: 300;
  line-height: 1;
}

/* ── 服装信息 ── */
.clothes-info {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 4rpx;
}

.clothes-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #3c2a1f;
}

.clothes-index {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(79, 57, 42, 0.08);
}

.clothes-index-text {
  font-size: 22rpx;
  color: #7a604b;
}

/* 当前正在切换的分类高亮，另一件略微透明 */
.clothes-active {
  opacity: 1;
}

.clothes-idle {
  opacity: 0.85;
}

/* 下拉菜单已选标签 */
.selected-tag {
  font-size: 18rpx;
  color: #8f6548;
  background: rgba(143, 101, 72, 0.12);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  margin-left: 12rpx;
}

/* 搭配概览提示条 */
.outfit-overview {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 16rpx;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, rgba(79, 57, 42, 0.08) 0%, rgba(143, 101, 72, 0.1) 100%);
  border-radius: 999rpx;
  border: 1rpx solid rgba(143, 101, 72, 0.2);
}

.outfit-overview-icon {
  font-size: 26rpx;
  color: #6a9e5a;
}

.outfit-overview-text {
  font-size: 24rpx;
  color: #5a3e2c;
  font-weight: 600;
}

.outfit-label {
  display: block;
  font-size: 20rpx;
  color: #a17f5d;
  letter-spacing: 2rpx;
  margin-bottom: 6rpx;
}

/* ── 指示点 ── */
.indicator {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
}

.indicator-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(111, 85, 63, 0.22);
}

.indicator-dot.active {
  width: 32rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4f392a 0%, #8f6548 100%);
}
