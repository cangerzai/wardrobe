/* pages/index/index.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #f0f9ff 0%, #e0f2fe 100%);
}

.header {
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #1e293b;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #64748b;
}

.canvas-wrapper {
  flex: 1;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.character-canvas {
  width: 600rpx;
  height: 800rpx;
  background-color: transparent;
}

.loading-tip {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  padding: 20rpx 40rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.clothes-info {
  padding: 30rpx 40rpx;
  text-align: center;
  background-color: rgba(255, 255, 255, 0.9);
  margin: 0 40rpx 40rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.clothes-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1e293b;
  margin-bottom: 10rpx;
}

.clothes-date {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
}

.indicator {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx 0 40rpx;
  gap: 16rpx;
}

.indicator-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #cbd5e1;
  transition: all 0.3s;
}

.indicator-dot.active {
  width: 32rpx;
  border-radius: 8rpx;
  background-color: #3cc51f;
}
