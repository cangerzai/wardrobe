<!-- pages/wardrobe/wardrobe.wxml -->
<view class="page">
  <view class="hero">
    <view class="hero-copy">
      <text class="eyebrow">LOOKBOOK WARDROBE</text>
      <text class="hero-title">我的衣橱</text>
      <text class="hero-subtitle">把日常服装整理成一册轻盈的数字时装簿，上传后自动生成卡通风格作品。</text>
    </view>

    <view class="hero-panel">
      <view class="stat-card stat-dark">
        <text class="stat-label">单品数量</text>
        <text class="stat-value">{{clothesList.length}}</text>
      </view>
      <view class="stat-card stat-light">
        <text class="stat-label">风格状态</text>
        <text class="stat-value stat-mini">AnimeGANv3</text>
      </view>
    </view>
  </view>

  <view class="upload-wrap">
    <button class="upload-card" bindtap="chooseImage" loading="{{isProcessing}}">
      <view class="upload-badge">NEW PROFIT</view>
      <text class="upload-title">上传新服装</text>
      <text class="upload-desc">支持拍照或从相册选择，上传后会自动生成卡通化服装图。</text>
      <view class="upload-action">
        <text class="upload-action-text">开始创建</text>
        <text class="upload-action-arrow">→</text>
      </view>
    </button>
  </view>

  <view class="section-head">
    <view>
      <text class="section-title">本季藏品</text>
      <text class="section-subtitle">保留原图与卡通图双视图，像翻阅一本属于你的数字 Lookbook</text>
    </view>
  </view>

  <view class="empty-state" wx:if="{{clothesList.length === 0}}">
    <view class="empty-orb"></view>
    <text class="empty-kicker">FIRST PIECE</text>
    <text class="empty-title">你的 Lookbook 还没有开始</text>
    <text class="empty-desc">先上传一件服装，让它变成属于你的第一张时尚插画。</text>
    <button class="empty-btn" bindtap="chooseImage">上传第一件服装</button>
  </view>

  <view class="gallery" wx:else>
    <view
      class="look-card"
      wx:for="{{clothesList}}"
      wx:key="id"
    >
      <view class="look-images">
        <view class="image-pane soft-pane" wx:if="{{item.originalUrl}}" bindtap="previewClothes" data-index="{{index}}" data-type="original">
          <text class="pane-label">原图</text>
          <image class="look-image" src="{{item.originalUrl}}" mode="aspectFill"></image>
        </view>
        <view class="image-pane accent-pane" bindtap="previewClothes" data-index="{{index}}" data-type="cartoon">
          <text class="pane-label">卡通图</text>
          <image class="look-image" src="{{item.cartoonUrl || item.originalUrl}}" mode="aspectFill"></image>
        </view>
      </view>

      <view class="look-footer">
        <view class="remark-row">
          <text class="remark-label">备注：</text>
          <input class="remark-input" type="text" placeholder="输入对这件衣服的备注" value="{{item.remark || ''}}" data-id="{{item.id}}" bindinput="onRemarkInput" />
        </view>
        <text class="delete-btn" catchtap="deleteClothes" data-id="{{item.id}}">移出衣橱</text>
      </view>
    </view>
  </view>

  <view class="processing-overlay" wx:if="{{isProcessing}}">
    <view class="processing-card">
      <view class="processing-ring"></view>
      <text class="processing-title">正在生成 Lookbook 单品</text>
      <text class="processing-desc">正在把你的服装转成卡通服装，请稍候片刻。</text>
    </view>
  </view>
</view>
