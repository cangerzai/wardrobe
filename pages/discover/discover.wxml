<!-- pages/discover/discover.wxml -->
<view class="page">

  <!-- 顶部入口区 -->
  <view class="entry-group">
    <view class="entry-card entry-publish" bindtap="goPublish">
      <view class="entry-icon-wrap"><text class="entry-icon">✦</text></view>
      <view class="entry-copy">
        <text class="entry-title">发布穿搭</text>
        <text class="entry-desc">上传图片，写下你的搭配灵感</text>
      </view>
      <text class="entry-arrow">→</text>
    </view>
    <view class="entry-card entry-myposts" bindtap="goMyPosts">
      <view class="entry-icon-wrap"><text class="entry-icon">≡</text></view>
      <view class="entry-copy">
        <text class="entry-title">我发布的帖子</text>
        <text class="entry-desc">查看和管理你发布过的内容</text>
      </view>
      <text class="entry-arrow">→</text>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-shell">
    <view class="search-bar">
      <text class="search-icon">⌕</text>
      <input
        class="search-input"
        placeholder="搜索穿搭灵感说明..."
        bindinput="onSearchInput"
        value="{{searchKeyword}}"
        placeholder-class="search-placeholder"
      />
    </view>
  </view>

  <!-- 风格分类标签筛选 -->
  <scroll-view class="category-tabs" scroll-x="true" show-scrollbar="false">
    <view class="category-tab {{activeFilter === '' ? 'active' : ''}}" bindtap="setFilter" data-tag="">
      <text class="category-text">全部</text>
    </view>
    <view
      class="category-tab {{activeFilter === item ? 'active' : ''}}"
      wx:for="{{styleOptions}}"
      wx:key="*this"
      bindtap="setFilter"
      data-tag="{{item}}"
    >
      <text class="category-text">{{item}}</text>
    </view>
  </scroll-view>

  <view class="section-head">
    <view>
      <text class="section-title">发现圈</text>
      <text class="section-subtitle">浏览大家分享的穿搭灵感</text>
    </view>
  </view>

  <view class="empty-state" wx:if="{{filteredList.length === 0}}">
    <view class="empty-orb"></view>
    <text class="empty-kicker">NO POSTS YET</text>
    <text class="empty-title">还没有穿搭分享</text>
    <text class="empty-desc">成为第一个在这里分享穿搭灵感的人吧。</text>
  </view>

  <view class="outfit-grid" wx:else>
    <view class="outfit-col outfit-col-left">
      <block wx:for="{{filteredList}}" wx:key="id">
        <view class="outfit-card" wx:if="{{index % 2 === 0}}">
          <image class="outfit-image" src="{{item.image}}" mode="widthFix" bindtap="goDetail" data-id="{{item.id}}"></image>
          <view class="outfit-body">
            <text class="outfit-title" bindtap="goDetail" data-id="{{item.id}}">{{item.desc || '无说明'}}</text>
            <view class="tags-display" wx:if="{{item.tags.length > 0}}">
              <text class="tag-item" wx:for="{{item.tags}}" wx:key="index" wx:for-item="tag"># {{tag}}</text>
            </view>
            <view class="card-footer">
              <view class="card-author-row">
                <image class="card-avatar" src="/images/default-avatar.png" mode="aspectFill"></image>
                <text class="username">{{item.username || '衣橱用户'}}</text>
              </view>
              <text class="outfit-time">{{item.timeLabel}}</text>
            </view>
            <view class="action-bar">
              <view class="action-btn-wrap" catchtap="toggleLike" data-id="{{item.id}}">
                <text class="action-icon {{item.liked ? 'icon-liked' : ''}}">♥</text>
                <text class="action-count">{{item.likes}}</text>
              </view>
              <view class="action-btn-wrap" catchtap="toggleFav" data-id="{{item.id}}">
                <text class="action-icon {{item.faved ? 'icon-faved' : ''}}">★</text>
                <text class="action-count">{{item.favs || 0}}</text>
              </view>
              <view class="action-btn-wrap" bindtap="goDetail" data-id="{{item.id}}">
                <text class="action-icon">💬</text>
                <text class="action-count">{{item.comments}}</text>
              </view>
            </view>
          </view>
        </view>
      </block>
    </view>
    <view class="outfit-col outfit-col-right">
      <block wx:for="{{filteredList}}" wx:key="id">
        <view class="outfit-card" wx:if="{{index % 2 === 1}}">
          <image class="outfit-image" src="{{item.image}}" mode="widthFix" bindtap="goDetail" data-id="{{item.id}}"></image>
          <view class="outfit-body">
            <text class="outfit-title" bindtap="goDetail" data-id="{{item.id}}">{{item.desc || '无说明'}}</text>
            <view class="tags-display" wx:if="{{item.tags.length > 0}}">
              <text class="tag-item" wx:for="{{item.tags}}" wx:key="index" wx:for-item="tag"># {{tag}}</text>
            </view>
            <view class="card-footer">
              <view class="card-author-row">
                <image class="card-avatar" src="/images/default-avatar.png" mode="aspectFill"></image>
                <text class="username">{{item.username || '衣橱用户'}}</text>
              </view>
              <text class="outfit-time">{{item.timeLabel}}</text>
            </view>
            <view class="action-bar">
              <view class="action-btn-wrap" catchtap="toggleLike" data-id="{{item.id}}">
                <text class="action-icon {{item.liked ? 'icon-liked' : ''}}">♥</text>
                <text class="action-count">{{item.likes}}</text>
              </view>
              <view class="action-btn-wrap" catchtap="toggleFav" data-id="{{item.id}}">
                <text class="action-icon {{item.faved ? 'icon-faved' : ''}}">★</text>
                <text class="action-count">{{item.favs || 0}}</text>
              </view>
              <view class="action-btn-wrap" bindtap="goDetail" data-id="{{item.id}}">
                <text class="action-icon">💬</text>
                <text class="action-count">{{item.comments}}</text>
              </view>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>

</view>
