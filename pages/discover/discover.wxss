/* pages/discover/discover.wxss */
.page {
  min-height: 100vh;
  padding: 32rpx 24rpx 48rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(212, 167, 98, 0.22), transparent 28%),
    radial-gradient(circle at left 16%, rgba(101, 79, 63, 0.12), transparent 24%),
    linear-gradient(180deg, #f8f2e9 0%, #efe4d2 42%, #eadcc9 100%);
}

.hero {
  background: linear-gradient(135deg, rgba(59, 43, 33, 0.96) 0%, rgba(90, 66, 50, 0.92) 58%, rgba(163, 118, 74, 0.88) 100%);
  border-radius: 36rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 20rpx 50rpx rgba(69, 43, 20, 0.18);
  color: #fff9f1;
  position: relative;
  overflow: hidden;
}

.hero::after {
  content: '';
  position: absolute;
  right: -44rpx;
  top: -24rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 237, 214, 0.08);
}

.hero-copy {
  position: relative;
  z-index: 1;
}

.eyebrow {
  display: block;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: rgba(255, 243, 225, 0.72);
  margin-bottom: 18rpx;
}

.hero-title {
  display: block;
  font-size: 60rpx;
  font-weight: 700;
  color: #fffaf3;
  margin-bottom: 18rpx;
}

.hero-subtitle {
  display: block;
  max-width: 600rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: rgba(255, 243, 225, 0.84);
}

.hero-panel {
  margin-top: 34rpx;
  display: flex;
  gap: 18rpx;
  position: relative;
  z-index: 1;
}

.hero-chip {
  flex: 1;
  border-radius: 26rpx;
  padding: 24rpx;
}

.primary-chip {
  background: rgba(255, 247, 236, 0.14);
  border: 1rpx solid rgba(255, 240, 220, 0.16);
}

.soft-chip {
  background: rgba(255, 248, 238, 0.9);
}

.chip-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 247, 236, 0.72);
}

.soft-chip .chip-label {
  color: #8a6c53;
}

.chip-value {
  display: block;
  margin-top: 14rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #fffaf2;
}

.soft-chip .chip-value {
  color: #4f3826;
}

.search-shell {
  margin-top: 28rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: rgba(255, 251, 247, 0.92);
  border-radius: 28rpx;
  padding: 0 24rpx;
  height: 96rpx;
  box-shadow: 0 14rpx 36rpx rgba(95, 67, 37, 0.08);
}

.search-icon {
  font-size: 30rpx;
  color: #8f7257;
}

.search-input {
  flex: 1;
  height: 96rpx;
  font-size: 28rpx;
  color: #3c2a1f;
}

.search-placeholder {
  color: #b19478;
}

.category-tabs {
  white-space: nowrap;
  margin-top: 24rpx;
}

.category-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx;
  margin-right: 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 244, 0.84);
  box-shadow: 0 8rpx 20rpx rgba(95, 67, 37, 0.08);
}

.category-tab.active {
  background: linear-gradient(135deg, #4f392a 0%, #8f6548 100%);
}

.category-text {
  font-size: 24rpx;
  color: #7f634b;
}

.category-tab.active .category-text {
  color: #fff5ea;
}

.section-head {
  margin: 34rpx 8rpx 22rpx;
}

.section-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #3b2b21;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8f7257;
}

.outfit-list {
  display: flex;
  flex-direction: column;
  gap: 26rpx;
}

.outfit-card {
  background: rgba(255, 251, 247, 0.92);
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 36rpx rgba(95, 67, 37, 0.1);
}

.outfit-image {
  width: 100%;
  height: 430rpx;
  background: #f1e5d7;
}

.outfit-body {
  padding: 28rpx;
}

.outfit-topline {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.outfit-kicker {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: #a17f5d;
}

.outfit-score {
  font-size: 22rpx;
  color: #8b6344;
}

.outfit-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #36251a;
  line-height: 1.5;
}

.author-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 24rpx;
}

.avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: #eadcc9;
}

.author-copy {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.username {
  font-size: 27rpx;
  font-weight: 700;
  color: #3a281c;
}

.author-note {
  font-size: 22rpx;
  color: #9a7d63;
}

.outfit-footer {
  margin-top: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.meta-item {
  font-size: 22rpx;
  color: #8f7257;
}

.meta-link {
  font-size: 22rpx;
  color: #5a4030;
}

.empty-state {
  position: relative;
  overflow: hidden;
  margin-top: 26rpx;
  background: rgba(255, 250, 244, 0.88);
  border-radius: 32rpx;
  padding: 90rpx 42rpx;
  text-align: center;
  box-shadow: 0 14rpx 36rpx rgba(95, 67, 37, 0.08);
}

.empty-orb {
  width: 180rpx;
  height: 180rpx;
  margin: 0 auto 26rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, #f8e8d1 0%, #d1ab7d 42%, #7e5c42 100%);
  opacity: 0.9;
}

.empty-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 5rpx;
  color: #a17f5d;
  margin-bottom: 14rpx;
}

.empty-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #3b2b21;
  margin-bottom: 16rpx;
}

.empty-desc {
  display: block;
  font-size: 24rpx;
  line-height: 1.9;
  color: #8c6f56;
}
