/* pages/publishPost/publishPost.wxss */
.page {
  min-height: 100vh;
  padding: 32rpx 24rpx 60rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(212, 167, 98, 0.22), transparent 28%),
    linear-gradient(180deg, #f8f2e9 0%, #efe4d2 42%, #eadcc9 100%);
}

.header {
  margin-bottom: 32rpx;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #3c2a1f;
  margin-bottom: 8rpx;
}

.header-sub {
  display: block;
  font-size: 24rpx;
  color: #8f7257;
}

.publish-image-zone {
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: rgba(255, 251, 247, 0.92);
  border: 2rpx dashed rgba(143, 101, 72, 0.3);
  min-height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(95, 67, 37, 0.07);
}

.publish-image-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 60rpx;
}

.publish-image-icon {
  font-size: 80rpx;
  color: #b5967a;
  line-height: 1;
}

.publish-image-tip {
  font-size: 26rpx;
  color: #9a7d63;
}

.publish-image-preview {
  position: relative;
  width: 100%;
}

.publish-preview-img {
  width: 100%;
  height: 400rpx;
  display: block;
}

.publish-image-change {
  position: absolute;
  bottom: 0;
  right: 0;
  padding: 10rpx 20rpx;
  background: rgba(46, 30, 20, 0.6);
  color: #fff9f1;
  font-size: 22rpx;
  border-top-left-radius: 12rpx;
}

.form-card {
  background: rgba(255, 251, 247, 0.92);
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(95, 67, 37, 0.07);
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.form-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #4c3625;
}

.form-textarea {
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(143, 101, 72, 0.07);
  border: 1rpx solid rgba(143, 101, 72, 0.15);
  font-size: 26rpx;
  color: #3c2a1f;
  min-height: 120rpx;
  line-height: 1.7;
}

.form-placeholder {
  color: #b5967a;
}

.form-count {
  font-size: 22rpx;
  color: #b5967a;
  text-align: right;
}

.style-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.style-tag-btn {
  padding: 16rpx 32rpx;
  border-radius: 999rpx;
  background: rgba(143, 101, 72, 0.08);
  border: 1rpx solid rgba(143, 101, 72, 0.18);
}

.style-tag-active {
  background: #4f392a;
  border-color: #4f392a;
}

.style-tag-text {
  font-size: 26rpx;
  color: #6b4f38;
}

.style-tag-active .style-tag-text {
  color: #fff9f1;
  font-weight: 700;
}

.publish-btn {
  width: 100%;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4f392a 0%, #8f6548 100%);
  color: #fff7ef;
  font-size: 30rpx;
  font-weight: 700;
  padding: 24rpx 0;
}

.publish-btn::after { border: none; }

.publishing { opacity: 0.7; }
